# Copie este fichero como "utilesia.env" en la misma carpeta que app.py.
# Las variables de entorno de Windows (o las del servicio NSSM) tienen prioridad.

# Log del mensaje completo enviado al LLM (incluye texto del PDF). Por defecto desactivado en código.
# Activar solo para depuración (puede ser muy voluminoso y contener datos sensibles).
UTILESIA_LOG_LLM_USER_PROMPT=0

# Recorte del log anterior en caracteres (12000 por defecto). 0 = registrar el mensaje completo.
# UTILESIA_LOG_LLM_PROMPT_MAX_CHARS=12000

# OCR, tablas, tokens LLM, etc. (descomente si aplica)
# UTILESIA_DISABLE_OCR=1
# UTILESIA_ENABLE_TABLE_EXTRACTION=1
# UTILESIA_LLM_MAX_TOKENS=8192

# Si hay LINEAS_DETALLE por coordenadas, no anadir TEXTO_PLANO al prompt (evita duplicar lineas con el LLM).
# Por defecto activo (1). Para volver a enviar el PDF en texto plano junto al layout: 0
# UTILESIA_SUPPRESS_PLAIN_WITH_LAYOUT=0
